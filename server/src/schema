TABLE users
isEveryone boolean
id string
username string
password_hash string
permission relation to permissions
created_by relation to users (optional)

TABLE backups
id string
path string
size int
created_at timestamp
created_by relation to users
file relation to files

TABLE files
path string
metadata json (optional, default = {})
type "file" | "folder" | "link"
mime_type string
size int
    link "http" | "local" | "base64_data_url" | "ftp" | "git" (optional)
    link_target string (optional) (can be deserialized json)
    cache boolean
    cache_dur int (milliseconds)

TABLE permissions
id string
weight int
isRoot boolean
create_api_key boolean
create_user boolean
delete_user boolean
edit_user boolean
view_user boolean
bypass_weight boolean
max_action_size int
max_backup_size int
total_storage_size int
max_create_users int
convert_file boolean

TABLE file_perms
id string
permission relation to permissions
path string
bypass_weight boolean
recursive boolean
read boolean
delete boolean
write boolean
create_file boolean
create_folder boolean
create_link boolean
create_backup boolean
create_with_weight boolean
generate_link boolean
encrypt boolean

TABLE keys
id string
key string
created_at timestamp
owner relation to users
permission relation to permissions

TABLE links
id string
file relation to files
created_at timestamp
expires_at timestamp (optional)
access_count int
max_access_count int (optional)
created_by relation to users
password_hash string (optional)
